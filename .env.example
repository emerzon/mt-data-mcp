# ── MT5 Connection ──────────────────────────────────────
# Uncomment and set these values for automatic login.
# All four are optional if MT5 is already logged in interactively.
# MT5_LOGIN=12345678
# MT5_PASSWORD=your_password
# MT5_SERVER=YourBroker-Demo
# MT5_TIMEOUT=30

# ── Timezone ───────────────────────────────────────────
# Optional broker session/calendar timezone (does not shift MT5 UTC epochs).
# Preferred over a fixed offset because it handles DST automatically.
# MT5_SERVER_TZ=Europe/Athens

# Optional fixed broker session/calendar offset from UTC in minutes.
# A non-zero value overrides MT5_SERVER_TZ.
# MT5_TIME_OFFSET_MINUTES=120

# Optional: override local machine timezone detection
# CLIENT_TZ=America/New_York

# ── Broker Time Check ──────────────────────────────────
# Optional runtime check for live MT5 tick/bar freshness and future timestamps.
# MTDATA_BROKER_TIME_CHECK=false
# MTDATA_BROKER_TIME_CHECK_TTL_SECONDS=60

# ── MCP Server ─────────────────────────────────────────
# MCP_TRANSPORT=sse
# FASTMCP_HOST=127.0.0.1
# FASTMCP_PORT=8000
# FASTMCP_ALLOW_REMOTE=0
# FASTMCP_LOG_LEVEL=INFO
# FASTMCP_MOUNT_PATH=/
# FASTMCP_SSE_PATH=/sse
# FASTMCP_MESSAGE_PATH=/message

# ── Web API ────────────────────────────────────────────
# WEBAPI_HOST=127.0.0.1
# WEBAPI_PORT=8000
# WEBAPI_ALLOW_REMOTE=0
# WEBAPI_AUTH_TOKEN=
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# WEBUI_DIST_DIR=webui/dist

# ── News Embeddings ────────────────────────────────────
# Disabled by default. Enabling may download the configured model on first use.
# MTDATA_NEWS_EMBEDDINGS_ENABLED=0
# MTDATA_NEWS_EMBEDDINGS_MODEL=Qwen/Qwen3-Embedding-0.6B
# MTDATA_NEWS_EMBEDDINGS_TOP_N=8
# MTDATA_NEWS_EMBEDDINGS_WEIGHT=1.0
# MTDATA_NEWS_EMBEDDINGS_CACHE_SIZE=256
# HF_TOKEN=

# ── Finviz ─────────────────────────────────────────────
# FINVIZ_HTTP_TIMEOUT=15.0
# FINVIZ_SCREENER_MAX_ROWS=5000

# ── Options Data ───────────────────────────────────────
# Default is the unauthenticated Yahoo endpoint, which can return 401/429.
# Use Tradier for reliable options chains.
# MTDATA_OPTIONS_PROVIDER=yahoo
# MTDATA_OPTIONS_PROVIDER=tradier
# MTDATA_OPTIONS_API_KEY=your_tradier_token
# MTDATA_OPTIONS_BASE_URL=https://api.tradier.com/v1

# ── Forecasting / GPU ──────────────────────────────────
# MTDATA_NF_ACCEL=cpu
# CUDA_VISIBLE_DEVICES=0

# ── Market Depth ───────────────────────────────────────
# MTDATA_ENABLE_MARKET_DEPTH_FETCH=0

# ── Trading ────────────────────────────────────────────
# MTDATA_TRADE_IDEMPOTENCY_DB=~/.mtdata/trade_idempotency.sqlite3
# MTDATA_TRADE_IDEMPOTENCY_TTL_SECONDS=86400

# ── CLI / Debug ────────────────────────────────────────
# MTDATA_CLI_DEBUG=0
# NO_COLOR=
